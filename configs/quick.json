{
  "name": "quick",
  "description": "5 seeds, short horizon — enough for trend check but not publication-grade",
  "seeds": [1, 2, 3, 4, 5],
  "horizon": 120,
  "shockT": 40,
  "burstLen": 20,
  "modes": ["baseline", "arc_v1", "arc_robust"],
